{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "FIREBASE_CONFIG": "@firebase_config",
    "JWT": "@jwt_secret",
    "ADMIN_USER": "@admin_user",
    "ADMIN_PASS": "@admin_pass",
    "TELEGRAM_TOKEN_ID": "@telegram_token",
    "TELEGRAM_CHAT_ID": "@telegram_chat"
  }
}
